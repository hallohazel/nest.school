// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")  // Di Versi 5, baris ini WAJIB ada di sini
}

model Student {
  id        Int      @id @default(autoincrement())
  nis       String   @unique
  name      String
  email     String?  @unique
  kelas     String
  jurusan   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi: Satu siswa bisa melakukan banyak peminjaman
  peminjaman Peminjaman[]
  users       User[]
}

model Book {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  title     String
  author    String
  publisher String
  year      Int
  stock     Int   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi: Satu buku bisa dipinjam berkali-kali (histori)
  peminjaman Peminjaman[]
}

model Peminjaman {
  id_peminjaman Int      @id @default(autoincrement())
  id_student    Int
  id_buku       Int
  tgl_pinjam    DateTime @default(now())
  tgl_kembali   DateTime                 // Tanggal jatuh tempo
  status        String   @default("DIPINJAM") // (DIPINJAM / KEMBALI)

  // Relasi
  student       Student  @relation(fields: [id_student], references: [id])
  book          Book     @relation(fields: [id_buku], references: [id])
}

enum UserRole {
  ADMIN 
  PETUGAS
  MEMBER
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      UserRole
  
  createdAt DateTime @default(now())

  memberId  Int?      // Pakai tanda tanya (?) karena Admin tidak punya NIS
  member    Student?  @relation(fields: [memberId], references: [id])
}
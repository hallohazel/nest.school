// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")  // Di Versi 5, baris ini WAJIB ada di sini
}

model Student {
  id        Int      @id @default(autoincrement())
  nis       String   @unique
  name      String
  email     String?  @unique
  kelas     String
  jurusan   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Walas {
  id_walas     Int      @id @default(autoincrement()) // [cite:57]
  nama_walas   String                                 // [cite:58]
  no_tlp       String                                 // [cite:59]                
  alamat_walas String                                 // [cite:60]
}